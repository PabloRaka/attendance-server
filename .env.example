########################################
# General Settings
########################################
# Provide a full SQLAlchemy URL to override all other DB_* settings.
DATABASE_URL=

# Dialect can be sqlite, postgres, or mysql. Defaults to sqlite when empty.
DATABASE_DIALECT=sqlite

# These fields are used when DATABASE_URL is empty.
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=attendance

# Path is only used when DATABASE_DIALECT resolves to sqlite.
SQLITE_PATH=./attendance.db


SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FACE_SIMILARITY_THRESHOLD=0.60